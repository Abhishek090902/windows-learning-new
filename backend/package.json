    "express": "^4.21.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.1",
    "stripe": "^18.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
